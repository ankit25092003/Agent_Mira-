{
  "name": "agent-mira-submission",
  "version": "1.0.0",
  "scripts": {
    "start": "concurrently \"npm run start-node\" \"npm run start-python\" \"npm run start-frontend\"",
    "start-node": "cd backend && node server.js",
    "start-python": "cd python_service && python -m uvicorn main:app --port 8000",
    "start-frontend": "cd frontend && npm run dev"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
